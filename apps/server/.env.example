NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/doodledraw

# Admin access: grant by flipping `isAdmin: true` on a registered user via Mongo shell:
#   db.playerProfiles.updateOne({ username: 'your_username' }, { $set: { isAdmin: true } })
# No ADMIN_USERNAME/PASSWORD env vars anymore — admins are regular users with the isAdmin flag set.
